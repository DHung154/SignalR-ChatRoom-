    private bool _isTypingSent = false;
    private DateTime _lastTypingSend = DateTime.MinValue;

    private async Task KeyHandler(KeyboardEventArgs e)
    {
        bool isChatTargetSelected = IsAiChatSelected ||
            !string.IsNullOrEmpty(selectedClient.Username) || !string.IsNullOrEmpty(selectedGroup.GroupName);
        string target = IsAiChatSelected ? AiAssistantName : (string.IsNullOrEmpty(selectedGroup.GroupName) ? selectedClient.Username : selectedGroup.GroupName);

        if (e.Key != "Enter" && isChatTargetSelected && !string.IsNullOrEmpty(TextMessage) && hubConnection != null && hubConnection.State == HubConnectionState.Connected)
        {
            if (DateTime.Now.Subtract(_lastTypingSend).TotalMilliseconds > 1500 || !_isTypingSent)
            {
                if (!string.IsNullOrEmpty(target))
                {

                    await hubConnection.SendAsync("SendTypingIndicator", target);
                    _lastTypingSend = DateTime.Now;
                    _isTypingSent = true;
                }
            }
        }
        else if (string.IsNullOrEmpty(TextMessage))
        {
            _isTypingSent = false;
        }


        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessageAsync(TextMessage, selectedGroup?.GroupName);
            _isTypingSent = false;
        }
        else if (e.Key == "Enter" && e.ShiftKey)
        {
            TextMessage += Environment.NewLine;
        }
    }

    // BỔ SUNG: Phương thức gửi cảm xúc (Reaction) (GIỮ NGUYÊN)
    private async Task SendReaction(ClientMessage msg, string reaction)
    {
        if (hubConnection == null || hubConnection.State != HubConnectionState.Connected)
        {
            NotificationMessages.Add(CreateToastMessage(ToastType.Warning, "Lỗi", "Kết nối Server bị ngắt. Không thể thả cảm xúc."));
            await InvokeAsync(StateHasChanged);
            return;
        }

        string targetUsernameOrGroupName = string.Empty;
        bool isGroup = false;

        if (IsAiChatSelected)
        {
            // Ngăn chặn thả reaction vào tin nhắn của AI Assistant.
            if (msg.SenderClientUsername.Equals(AiAssistantName))
            {
                NotificationMessages.Add(CreateToastMessage(ToastType.Warning, "Thao tác thất bại", "Không thể thả cảm xúc cho tin nhắn của AI Assistant."));
                await InvokeAsync(StateHasChanged);
                return;
            }
            targetUsernameOrGroupName = AiAssistantName;
        }
        else if (!string.IsNullOrEmpty(selectedGroup.GroupName))
        {
            // Group Chat
            targetUsernameOrGroupName = selectedGroup.GroupName;
            isGroup = true;
        }
        else if (!string.IsNullOrEmpty(selectedClient.Username))
        {
            // Private Chat
            targetUsernameOrGroupName = selectedClient.Username;
        }

        if (string.IsNullOrEmpty(targetUsernameOrGroupName)) return;

        // 1. Cập nhật local trước
        // Bật/Tắt cảm xúc: Nếu reaction đã có VÀ giống reaction đang click thì xóa (string.Empty), nếu khác thì gán reaction mới.
        msg.Reaction = msg.Reaction == reaction ? string.Empty : reaction;

        HideReactionMenu();

        // Lọc lại message để cập nhật UI
        FilterUserMessages(isGroup ? selectedGroup.GroupName : IsAiChatSelected ? AiAssistantName : selectedClient.Username, isGroup);
        await InvokeAsync(StateHasChanged);

        // 2. GỌI SERVER (Nếu không phải chat AI)
        if (!IsAiChatSelected)
        {
            // Server sẽ gửi reaction đến người nhận/nhóm
            // Do đã sửa Server để gửi cho cả hai, logic Client này là đủ.
            await hubConnection.SendAsync("SendReactionAsync", targetUsernameOrGroupName, msg.MessageId, msg.Reaction);
        }
    }

