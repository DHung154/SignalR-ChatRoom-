    private ToastMessage CreateToastMessage(ToastType toastType, string title, string message)
    => new ToastMessage
    {
        Type = toastType,
        Title = title,
        HelpText = $"{DateTime.Now}",
        Message = $"{message}",
    };
    private ToastMessage CreateToastMessage(ToastType toastType, string message)
    => CreateToastMessage(toastType, "Thông báo", message);

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null)
            return;

        if (string.IsNullOrEmpty(selectedClient.Username) && string.IsNullOrEmpty(selectedGroup.GroupName) && !IsAiChatSelected)
        {
            NotificationMessages.Add(CreateToastMessage(ToastType.Warning, "Lỗi", "Vui lòng chọn người dùng, phòng hoặc AI Assistant để gửi ảnh."));
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10_000_000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            string base64 = Convert.ToBase64String(ms.ToArray());
            string imageUrl = $"data:{file.ContentType};base64,{base64}";

            await SendImageMessage(imageUrl);
        }
        catch (Exception ex)
        {
            NotificationMessages.Add(CreateToastMessage(ToastType.Danger, "Lỗi Tải Ảnh", $"Không thể xử lý file. Lỗi: {ex.Message}"));
            await InvokeAsync(StateHasChanged);
        }
    }


