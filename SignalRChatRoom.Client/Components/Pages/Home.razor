        }
    }

    private async Task SendImageMessage(string base64Img)
    {
        if (IsAiChatSelected || !string.IsNullOrEmpty(selectedClient.Username))
        {
            // Chat AI và Chat Riêng đều dùng SendMessageAsync với groupName = null
            await SendMessageAsync(base64Img, null);
        }
        else if (!string.IsNullOrEmpty(selectedGroup.GroupName))
        {
            await SendMessageAsync(base64Img, selectedGroup.GroupName);
        }
    }
