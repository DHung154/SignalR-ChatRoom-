    public async Task<bool> CheckUsernameAsync(string username)
    {
        Client client = Clients.FirstOrDefault(c => c.Username.Equals(username));
        return (client == null);
    }

    public async Task<bool> CheckGroupNameAsync(string groupName)
    {
        Group group = Groups.FirstOrDefault(g => g.GroupName.Equals(groupName));
        return (group == null);
    }

    async Task SignIn()
    {
        if (hubConnection == null || hubConnection.State != HubConnectionState.Connected)
        {
            AuthenticationMessages.Add(CreateToastMessage(ToastType.Danger, "Lỗi", "Kết nối Server bị ngắt. Vui lòng thử lại."));
            return;
        }

        if (!string.IsNullOrEmpty(CallerUsername))
        {
            bool result = await CheckUsernameAsync(CallerUsername);
            if (result)
            {
                await hubConnection.SendAsync("GetUsernameAsync", CallerUsername);
                IsAuthenticated = true;
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                AuthenticationMessages.Add(CreateToastMessage(ToastType.Warning, "Đăng nhập thất bại", "Tên người dùng đã bị sử dụng!"));
            }
        }
    }

    List<ClientMessage> SelectedUserMessages = new List<ClientMessage>();

    void FilterUserMessages(string receiverClientNameOrGroupName, bool IsGroupMessage)
    {
        if (string.IsNullOrEmpty(receiverClientNameOrGroupName))
        {
            SelectedUserMessages.Clear();
            return;
        }

        // BỔ SUNG: Lọc tin nhắn cho AI Chat
        if (receiverClientNameOrGroupName.Equals(AiAssistantName))
        {
            SelectedUserMessages = Messages
            .Where(msg =>
              !msg.IsGroupMessage && (
               (msg.SenderClientUsername.Equals(CallerUsername) && msg.ReceiverClientUsernameOrGroupName.Equals(AiAssistantName)) || // Tin gửi

               (msg.SenderClientUsername.Equals(AiAssistantName) && msg.ReceiverClientUsernameOrGroupName.Equals(CallerUsername)) // Tin nhận
                      )
            )
            .OrderBy(msg => msg.CreatedDate)
            .ToList();
            return;
        }

        if (IsGroupMessage)
        {
            SelectedUserMessages = Messages
            .Where(msg => msg.IsGroupMessage && msg.ReceiverClientUsernameOrGroupName.Equals(receiverClientNameOrGroupName))
            .OrderBy(msg => msg.CreatedDate)
            .ToList();
        }
        else
        {
            SelectedUserMessages = Messages
            .Where(msg =>
              !msg.IsGroupMessage && (
               (msg.SenderClientUsername.Equals(CallerUsername) && msg.ReceiverClientUsernameOrGroupName.Equals(receiverClientNameOrGroupName)) ||
               (msg.SenderClientUsername.Equals(receiverClientNameOrGroupName) && msg.ReceiverClientUsernameOrGroupName.Equals(CallerUsername))

              )
            )
            .OrderBy(msg => msg.CreatedDate)
            .ToList();
        }
    }

    private void SelectClient(Client client)
    {
        IsAiChatSelected = false; // BỔ SUNG: Tắt chế độ AI Chat
        selectedClient = client;
        selectedGroup = new Group();
        ClientsOfGroups.Clear();
        displayStyle = "none";
        TypingUser = string.Empty;

        FilterUserMessages(client.Username, false);
        InvokeAsync(StateHasChanged);
    }

    private async Task SelectGroup(Group group)
    {
        IsAiChatSelected = false; // BỔ SUNG: Tắt chế độ AI Chat
        selectedGroup = group;
        selectedClient = new Client();

        if (hubConnection != null && hubConnection.State == HubConnectionState.Connected)
        {
            await AddClientToGroup(selectedGroup.GroupName);
            await GetClientsOfGroup(selectedGroup.GroupName);
        }

        displayStyle = "block";
        TypingUser = string.Empty;

        FilterUserMessages(group.GroupName, true);
        await InvokeAsync(StateHasChanged);
    }

    // BỔ SUNG: Phương thức chọn AI Chat
    private async Task SelectAiChat()
    {
        IsAiChatSelected = true;
        selectedClient = new Client();
        selectedGroup = new Group();
        ClientsOfGroups.Clear();
        displayStyle = "none";
        TypingUser = string.Empty;

        FilterUserMessages(AiAssistantName, false);

        await InvokeAsync(StateHasChanged);
        await ScrollToBottom();
    }


    async Task SendMessageAsync(string message, string? groupName)
    {
        if (hubConnection == null || hubConnection.State != HubConnectionState.Connected)
        {
            NotificationMessages.Add(CreateToastMessage(ToastType.Warning, "Lỗi", "Kết nối Server bị ngắt. Không thể gửi."));
            await InvokeAsync(StateHasChanged);
            return;
        }

        // Cập nhật điều kiện kiểm tra mục tiêu chat
        bool isChatTargetSelected = IsAiChatSelected ||
            !string.IsNullOrEmpty(selectedClient.Username) || !string.IsNullOrEmpty(selectedGroup.GroupName);

        if (string.IsNullOrEmpty(message) || !isChatTargetSelected)
        {
            if (!isChatTargetSelected)
            {
                NotificationMessages.Add(CreateToastMessage(ToastType.Warning, "Thao tác thất bại", "Vui lòng chọn người dùng, phòng, hoặc AI Assistant."));
                await InvokeAsync(StateHasChanged);
            }
            return;
        }

        try
        {
            TypingUser = string.Empty;
            _typingCancellationTokenSource?.Cancel();

            // ⭐ KHẮC PHỤC LỖI CHÍNH: Tạo ID duy nhất ở Client và sử dụng nó
            string newMessageId = Guid.NewGuid().ToString();
            bool isGroup = !string.IsNullOrEmpty(groupName);
            string targetName = isGroup ? groupName : (IsAiChatSelected ? AiAssistantName : selectedClient.Username);


            // 1. THÊM MESSAGE VÀO LOCAL TRƯỚC (Cho tất cả các loại chat để sender thấy ngay lập tức)
            Messages.Add(new ClientMessage()
            {
                MessageId = newMessageId,
                Message = message,
                ReceiverClientUsernameOrGroupName = targetName,
                SenderClientUsername = CallerUsername,
                IsSenderReceiver = true,
                IsGroupMessage = isGroup,
                CreatedDate = DateTime.Now
            });

            FilterUserMessages(targetName, isGroup);
            await InvokeAsync(StateHasChanged);
            await ScrollToBottom();


            if (IsAiChatSelected)
            {
                // GỌI SERVER VÀ TRUYỀN ID
                await hubConnection.SendAsync("SendMessageToAiAsync", message, newMessageId); // ⭐ ĐÃ SỬA: TRUYỀN messageId
            }
            else if (isGroup)
            {
                // GỌI SERVER VÀ TRUYỀN ID
                await hubConnection.SendAsync("SendMessageToGroupAsync", groupName, message, newMessageId); // ⭐ ĐÃ SỬA: TRUYỀN messageId
            }
            else if (!string.IsNullOrEmpty(selectedClient.Username))
            {
                // GỌI SERVER VÀ TRUYỀN ID
                await hubConnection.SendAsync("SendMessageAsync", message, selectedClient, newMessageId); // ⭐ ĐÃ SỬA: TRUYỀN messageId
            }

            if (!message.StartsWith("data:image"))
            {
                TextMessage = string.Empty;
            }
        }
        catch (Exception ex)
        {
            NotificationMessages.Add(CreateToastMessage(ToastType.Danger, "Lỗi Gửi", $"Không thể gửi tin nhắn/ảnh. Lỗi: {ex.Message}"));
            await InvokeAsync(StateHasChanged);
        }
    }

    async Task AddGroup(string groupNameInput)
    {
        if (hubConnection == null || hubConnection.State != HubConnectionState.Connected)
        {
            NotificationMessages.Add(CreateToastMessage(ToastType.Warning, "Lỗi", "Kết nối Server bị ngắt. Không thể tạo nhóm."));
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!string.IsNullOrEmpty(groupNameInput))
        {
            bool result = await CheckGroupNameAsync(groupNameInput);
            if (result) // Nếu tên phòng có thể sử dụng..
            {
                // 1. Kích hoạt Server để tạo nhóm
                await hubConnection.SendAsync("AddGroupAsync", groupNameInput);

                string newGroupName = GroupNameInput; // Lưu tên nhóm
                GroupNameInput = string.Empty;

                // 2. Chờ một khoảng ngắn (200ms) để Server gửi lại danh sách Groups đã cập nhật
                await Task.Delay(200);

                Group newGroup = Groups.FirstOrDefault(g => g.GroupName.Equals(newGroupName));

                if (newGroup != null)
                {
                    // 3. Tự động chọn nhóm vừa tạo (Tham gia + Hiển thị thành viên/tin nhắn)
                    await SelectGroup(newGroup);
                    NotificationMessages.Add(CreateToastMessage(ToastType.Success, "Thành công", $"Phòng **{newGroupName}** đã được tạo và bạn đã tham gia."));
                }
            }
            else
            {
                NotificationMessages.Add(CreateToastMessage(ToastType.Warning, "Thao tác thất bại", "Phòng có tên này đã tồn tại!"));
            }
        }
    }

